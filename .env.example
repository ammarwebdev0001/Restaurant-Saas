DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

WEATHER_API=your_weather_api_key

NEXTAUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Resend (https://resend.com) — transactional email (invites, welcome mail)
# Server-side only. Do NOT use NEXT_PUBLIC_RESEND_*.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
# Default for Resend test domain; use a verified domain in production, e.g. "Restaurant <noreply@yourdomain.com>"
RESEND_FROM_EMAIL="onboarding@resend.dev"


GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_CURRENCY=eur

NEXT_PUBLIC_APP_URL=http://localhost:3000 # Your app URL (e.g., https://yourdomain.com)

# Platform SaaS admin: optional env allowlist (in addition to account role platform admin → ADMIN).
# Marketing contact form (/api/contact) also notifies these addresses.
# ADMIN_EMAIL=you@example.com
# Or comma-separated: ADMIN_EMAILS=a@x.com,b@y.com

