# Copy to `.env` or `.env.local` and fill in values. Never commit real secrets.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/YOUR_DB?schema=public"

NEXTAUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Resend (https://resend.com) — transactional email (invites, welcome mail)
# Server-side only. Do NOT use NEXT_PUBLIC_RESEND_*.
# No quotes needed: RESEND_API_KEY=re_xxxx
# After changing .env, restart `npm run dev` so Next.js reloads env.
RESEND_API_KEY=
# With onboarding@resend.dev, Resend often only delivers to YOUR Resend signup email until you add & verify a domain.
RESEND_FROM_EMAIL=onboarding@resend.dev
