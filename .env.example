# Copy to `.env` and fill in real values. Never commit `.env`.
# Example file uses placeholders only — GitHub push protection rejects real-looking secrets here.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/restaurant_saas?schema=public"

# Optional: weather widget / APIs (use your own key)
WEATHER_API="your-openweathermap-or-service-key"

NEXTAUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Resend (https://resend.com) — transactional email (invites, welcome mail)
# Server-side only. Do NOT use NEXT_PUBLIC_RESEND_*.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Restaurant <onboarding@resend.dev>"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# Stripe (https://dashboard.stripe.com)
# IMPORTANT: server key must be `sk_*` (never `pk_*`).
STRIPE_SECRET_KEY="sk_test_your_secret_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"
STRIPE_CURRENCY="EUR"   # EUR
# Comma-separated Checkout methods. PayPal shows only if enabled in Stripe account.
STRIPE_CHECKOUT_METHODS="card,link,paypal"
# Optional: force canonical origin for success/cancel URLs.
NEXT_PUBLIC_APP_URL="http://localhost:3000"