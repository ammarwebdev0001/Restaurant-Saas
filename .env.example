# =============================================================================
# Restaurant SaaS — example environment.
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# Postgres (Prisma) — connection URL with sslmode=require for hosted DBs.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# NextAuth.js
NEXTAUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your_google_oauth_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
VERCEL_URL="localhost:3000"

# POS terminal companion service (Stripe Terminal / local register integrations).
NEXT_PUBLIC_POS_TERMINAL_API="http://127.0.0.1:5055"

# Platform / SaaS admin allowlist (in addition to account role ADMIN).
# Marketing contact form (/api/contact) also notifies these addresses.
# Comma-separated for multiple admins.
# ADMIN_EMAIL=you@example.com
# ADMIN_EMAILS=a@example.com,b@example.com

# PayPal — https://developer.paypal.com/dashboard/applications
PAYPAL_MODE="sandbox"
PAYPAL_CLIENT_ID="your_paypal_client_id"
PAYPAL_CLIENT_SECRET="your_paypal_client_secret"

# SMTP (transactional email — invites, password reset, contact form, welcome mail)
# Gmail setup:
#   1) Enable 2-Step Verification:      https://myaccount.google.com/security
#   2) Generate a 16-char App Password: https://myaccount.google.com/apppasswords
#   3) Paste the App Password into SMTP_PASSWORD (spaces are stripped automatically).
#   4) SMTP_FROM_EMAIL must match SMTP_USER or a verified "Send mail as" alias.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your.account@example.com"
SMTP_PASSWORD="xxxxxxxxxxxxxxxx"
SMTP_FROM_EMAIL="Restaurant <your.account@example.com>"
