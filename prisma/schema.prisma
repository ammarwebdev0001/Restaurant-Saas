// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

generator custom_generator {
  provider = "prisma-generator-fake-data"
}

// Disabled because prisma-dbml-generator currently crashes on this schema.
// Re-enable once the generator issue is fixed.
// generator dbml {
//   provider = "prisma-dbml-generator"
// }

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  WORKER
  UNKNOW
}

enum AttributeSelectionType {
  SINGLE
  MULTIPLE
}

enum SubscriptionPlan {
  STARTER
  GROWTH
  SCALE
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELED
}

enum CatProduct {
  ELECTRO
  DRINK
  FOOD
  FASHION
}

model User {
  id            String    @id @default(cuid())
  name          String
  username      String
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restarrants Restaurant[]
  employees   Employee[]
}

model Role {
  id           String @id @default(uuid())
  name         String
  restaurantId String

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  permissions Permission[]
  employees   Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id     String  @id @default(uuid())
  name   String
  role   Role?   @relation(fields: [roleId], references: [id])
  roleId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Restaurant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  subdomain String   @unique
  logoUrl   String?
  logoKey   String?
  mainBannerUrl String?
  menuBannerUrls String[] @default([])
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User           @relation(fields: [ownerId], references: [id])
  roles     Role[]
  menus     MenuCategory[]
  menuItems MenuItem[]
  orders    Order[]
  payments  Payment[]
  employees Employee[]
  customers Customer[]
  branches  Branch[]
  subscription RestaurantSubscription?
}

model Branch {
  id             String   @id @default(uuid())
  restaurantId   String
  name           String
  address        String?
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model RestaurantSubscription {
  id               String             @id @default(uuid())
  restaurantId     String             @unique
  plan             SubscriptionPlan   @default(STARTER)
  status           SubscriptionStatus @default(TRIAL)
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  notes            String?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id           String @id @default(uuid())
  restaurantId String
  userId       String
  roleId       String

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  role       Role       @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuCategory {
  id           String @id @default(uuid())
  name         String
  restaurantId String

  items                   MenuItem[]
  restaurant              Restaurant @relation(fields: [restaurantId], references: [id])
  linkedByAttributeGroups MenuItemAttributeGroup[] @relation("AttributeLinkedCategory")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id           String  @id @default(uuid())
  name         String
  description  String?
  imageUrl     String?
  imageKey     String?
  price        Float
  salePrice    Float?
  categoryId   String
  restaurantId String

  category          MenuCategory             @relation(fields: [categoryId], references: [id])
  restaurant        Restaurant               @relation(fields: [restaurantId], references: [id])
  orderItems        OrderItem[]
  attributeGroups   MenuItemAttributeGroup[]
  orderAddonChoices OrderItemModifier[]      @relation("OrderAddonProduct")

  offersFromThis MenuItemOffer[] @relation("BaseItemOffers")
  offeredAs     MenuItemOffer[]  @relation("OfferedItems")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItemOffer {
  id            String @id @default(uuid())
  baseItemId    String
  offeredItemId String
  sortOrder     Int    @default(0)

  baseItem    MenuItem @relation("BaseItemOffers", fields: [baseItemId], references: [id], onDelete: Cascade)
  offeredItem MenuItem @relation("OfferedItems", fields: [offeredItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([baseItemId])
}

model MenuItemAttributeGroup {
  id               String                 @id @default(uuid())
  menuItemId       String
  name             String
  sortOrder        Int                    @default(0)
  selectionType    AttributeSelectionType @default(SINGLE)
  required         Boolean                @default(false)
  linkedCategoryId String

  menuItem       MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  linkedCategory MenuCategory @relation("AttributeLinkedCategory", fields: [linkedCategoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([menuItemId])
  @@index([linkedCategoryId])
}

model Customer {
  id           String  @id @default(uuid())
  name         String
  email        String?
  phone        String
  restaurantId String

  orders     Order[]
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id           String   @id @default(uuid())
  restaurantId String
  customerId   String?
  status       String
  total        Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items      OrderItem[]
  payments   Payment[]
  restaurant Restaurant  @relation(fields: [restaurantId], references: [id])
  customer   Customer?   @relation(fields: [customerId], references: [id])
}

model OrderItem {
  id         String @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  price      Float

  order     Order                 @relation(fields: [orderId], references: [id])
  menuItem  MenuItem              @relation(fields: [menuItemId], references: [id])
  modifiers OrderItemModifier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItemModifier {
  id          String @id @default(uuid())
  orderItemId String
  menuItemId  String
  name        String
  unitPrice   Float
  quantity    Int    @default(1)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addonItem MenuItem  @relation("OrderAddonProduct", fields: [menuItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderItemId])
}

model Payment {
  id      String @id @default(uuid())
  orderId String
  amount  Float
  status  String
  method  String

  order Order @relation(fields: [orderId], references: [id])

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  restaurantId String?
}

model ProductStock {
  id           String     @id @unique
  name         String
  imageProduct String?
  price        Float
  stock        Float
  cat          CatProduct

  Product Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id            String          @id @default(cuid())
  productId     String
  productstock  ProductStock    @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sellprice     Float
  OnSaleProduct OnSaleProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId])
}

model OnSaleProduct {
  id            String      @id @default(cuid())
  productId     String
  quantity      Int
  saledate      DateTime    @default(now())
  transactionId String
  product       Product     @relation(fields: [productId], references: [productId], onDelete: Cascade, onUpdate: Cascade)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, transactionId])
}

model Transaction {
  id          String          @id @default(cuid())
  totalAmount Decimal?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  isComplete  Boolean         @default(false)
  products    OnSaleProduct[]
}

model ShopData {
  id        String   @id @default(cuid())
  tax       Int?
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
