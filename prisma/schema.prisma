// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

generator custom_generator {
  provider = "prisma-generator-fake-data"
}

// Disabled because prisma-dbml-generator currently crashes on this schema.
// Re-enable once the generator issue is fixed.
// generator dbml {
//   provider = "prisma-dbml-generator"
// }

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AttributeSelectionType {
  SINGLE
  MULTIPLE
}

enum SubscriptionPlan {
  STARTER
  GROWTH
  SCALE
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELED
}

enum EmployeeInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum CatProduct {
  ELECTRO
  DRINK
  FOOD
  FASHION
}

// How the order was created: POS, web (online), walk-in register, kiosk, or other.
enum OrderSourceType {
  POS
  ONLINE
  WALK_IN
  KIOSK
  OTHER
}

model User {
  id            String    @id @default(cuid())
  name          String
  username      String
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  roleId        String?
  accountRole   Role?     @relation("UserAccountRole", fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restarrants          Restaurant[]
  employees            Employee[]
  employeeInvitesSent  EmployeeInvite[]      @relation("EmployeeInvitesSent")
  subscriptionPayments SubscriptionPayment[] @relation("SubscriptionPaymentRecordedBy")
}

model Role {
  id           String  @id @default(uuid())
  name         String
  // Preset: owner | admin (per restaurant); platform: platform_admin | pending_owner | pending_worker
  slug         String?
  // Null = platform-wide role (SaaS admin, pending signup roles)
  restaurantId String?

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  permissions     Permission[]
  employees       Employee[]
  employeeInvites EmployeeInvite[]
  accountUsers    User[]           @relation("UserAccountRole")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, slug])
}

model Permission {
  id     String  @id @default(uuid())
  name   String
  role   Role?   @relation(fields: [roleId], references: [id])
  roleId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Restaurant {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  subdomain      String   @unique
  logoUrl        String?
  logoKey        String?
  mainBannerUrl  String?
  themePrimaryColor String?
  menuBannerUrls String[] @default([])
  ownerId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner                User                    @relation(fields: [ownerId], references: [id])
  roles                Role[]
  menus                MenuCategory[]
  menuItems            MenuItem[]
  orders               Order[]
  payments             Payment[]
  employees            Employee[]
  employeeInvites      EmployeeInvite[]
  customers            Customer[]
  branches             Branch[]
  subscription         RestaurantSubscription?
  subscriptionPayments SubscriptionPayment[]
  saleTransactions     Transaction[]
  kitchenTickets       KitchenTicket[]
  diningTables         DiningTable[]
}

/// Seating labels for POS table service (managed per restaurant).
model DiningTable {
  id             String   @id @default(uuid())
  restaurantId String
  name           String
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model Branch {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  address      String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model RestaurantSubscription {
  id               String             @id @default(uuid())
  restaurantId     String             @unique
  plan             SubscriptionPlan   @default(STARTER)
  status           SubscriptionStatus @default(TRIAL)
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  notes            String?

  restaurant Restaurant            @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  payments   SubscriptionPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubscriptionCatalog {
  id          String           @id @default(uuid())
  plan        SubscriptionPlan @unique
  name        String
  price       Int
  priceLabel  String
  description String
  features    String[]         @default([])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model SubscriptionPayment {
  id                       String    @id @default(uuid())
  restaurantId             String
  restaurantSubscriptionId String?
  amount                   Float
  currency                 String    @default("EUR")
  paidAt                   DateTime  @default(now())
  periodStart              DateTime?
  periodEnd                DateTime?
  notes                    String?
  recordedByUserId         String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  restaurant   Restaurant              @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  subscription RestaurantSubscription? @relation(fields: [restaurantSubscriptionId], references: [id], onDelete: SetNull)
  recordedBy   User?                   @relation("SubscriptionPaymentRecordedBy", fields: [recordedByUserId], references: [id], onDelete: SetNull)

  @@index([restaurantId, paidAt])
  @@index([restaurantSubscriptionId])
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DemoRequest {
  id             String   @id @default(cuid())
  name           String
  email          String
  restaurantName String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([createdAt])
}

model Employee {
  id           String @id @default(uuid())
  restaurantId String
  userId       String
  roleId       String

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  role       Role       @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, restaurantId])
}

// Pending join for an existing account; new users get Employee + set-password email immediately.
model EmployeeInvite {
  id           String               @id @default(uuid())
  restaurantId String
  email        String
  roleId       String
  token        String               @unique
  status       EmployeeInviteStatus @default(PENDING)
  invitedById  String
  expiresAt    DateTime
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  invitedBy  User       @relation("EmployeeInvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([restaurantId, email])
}

model MenuCategory {
  id           String @id @default(uuid())
  name         String
  restaurantId String

  items                   MenuItem[]
  restaurant              Restaurant               @relation(fields: [restaurantId], references: [id])
  linkedByAttributeGroups MenuItemAttributeGroup[] @relation("AttributeLinkedCategory")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id           String  @id @default(uuid())
  name         String
  description  String?
  imageUrl     String?
  imageKey     String?
  price        Float
  salePrice    Float?
  categoryId   String
  restaurantId String

  category          MenuCategory             @relation(fields: [categoryId], references: [id])
  restaurant        Restaurant               @relation(fields: [restaurantId], references: [id])
  orderItems        OrderItem[]
  attributeGroups   MenuItemAttributeGroup[]
  variations        MenuItemVariation[]
  orderAddonChoices OrderItemModifier[]      @relation("OrderAddonProduct")

  offersFromThis MenuItemOffer[] @relation("BaseItemOffers")
  offeredAs      MenuItemOffer[] @relation("OfferedItems")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItemVariation {
  id         String  @id @default(uuid())
  menuItemId String
  name       String
  title      String
  imageUrl   String?
  imageKey   String?
  swatchHex  String?
  sortOrder  Int     @default(0)
  priceDelta Float   @default(0)

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([menuItemId, sortOrder])
}

model MenuItemOffer {
  id            String @id @default(uuid())
  baseItemId    String
  offeredItemId String
  sortOrder     Int    @default(0)

  baseItem    MenuItem @relation("BaseItemOffers", fields: [baseItemId], references: [id], onDelete: Cascade)
  offeredItem MenuItem @relation("OfferedItems", fields: [offeredItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([baseItemId])
}

model MenuItemAttributeGroup {
  id               String                 @id @default(uuid())
  menuItemId       String
  name             String
  sortOrder        Int                    @default(0)
  selectionType    AttributeSelectionType @default(SINGLE)
  required         Boolean                @default(false)
  linkedCategoryId String

  menuItem       MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  linkedCategory MenuCategory @relation("AttributeLinkedCategory", fields: [linkedCategoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([menuItemId])
  @@index([linkedCategoryId])
}

model Customer {
  id           String  @id @default(uuid())
  name         String
  email        String?
  phone        String
  restaurantId String

  orders     Order[]
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id             String          @id @default(uuid())
  /// Short public-facing id for easy tracking (keep `id` as stable internal PK).
  shortOrderId   String          @unique @default(dbgenerated("upper(substring(replace(gen_random_uuid()::text, '-', ''), 1, 6))")) @db.VarChar(6)
  restaurantId   String
  customerId     String?
  /// Daily ticket number (resets from 0 each day per restaurant).
  ticketNumber   Int?
  /// Date bucket for daily ticket sequence.
  ticketDate     DateTime?       @db.Date
  status         String
  total          Float
  sourceType     OrderSourceType @default(OTHER)
  /// Delivery / service address snapshot (e.g. POS take-away or delivery).
  address        String?
  /// Tax amount applied at checkout (currency units, same as `total`).
  taxAmount      Float           @default(0)
  /// Order-level discount amount (not line-item discounts).
  discountAmount Float           @default(0)
  /// POS dine-in: linked `DiningTable` while it exists.
  diningTableId  String?
  /// Snapshot of table name at checkout (kept if the table row is removed).
  tableLabel     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  items          OrderItem[]
  payments       Payment[]
  kitchenTickets KitchenTicket[]
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id])
  diningTable    DiningTable?    @relation(fields: [diningTableId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([sourceType])
  @@index([diningTableId])
  @@index([restaurantId, ticketDate])
  @@unique([restaurantId, ticketDate, ticketNumber])
}

model OrderItem {
  id         String @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  price      Float

  order     Order               @relation(fields: [orderId], references: [id])
  menuItem  MenuItem            @relation(fields: [menuItemId], references: [id])
  modifiers OrderItemModifier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItemModifier {
  id          String @id @default(uuid())
  orderItemId String
  menuItemId  String
  name        String
  unitPrice   Float
  quantity    Int    @default(1)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addonItem MenuItem  @relation("OrderAddonProduct", fields: [menuItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderItemId])
}

model Payment {
  id      String @id @default(uuid())
  orderId String
  amount  Float
  status  String
  method  String

  order Order @relation(fields: [orderId], references: [id])

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  restaurantId String?
}

model ProductStock {
  id           String     @id @unique
  name         String
  imageProduct String?
  price        Float
  stock        Float
  cat          CatProduct

  Product Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id            String          @id @default(cuid())
  productId     String
  productstock  ProductStock    @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sellprice     Float
  OnSaleProduct OnSaleProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId])
}

model OnSaleProduct {
  id            String      @id @default(cuid())
  productId     String
  quantity      Int
  saledate      DateTime    @default(now())
  transactionId String
  product       Product     @relation(fields: [productId], references: [productId], onDelete: Cascade, onUpdate: Cascade)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, transactionId])
}

model Transaction {
  id           String          @id @default(cuid())
  restaurantId String?
  sourceType   OrderSourceType @default(WALK_IN)
  totalAmount  Decimal?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  isComplete   Boolean         @default(false)
  products     OnSaleProduct[]
  restaurant   Restaurant?     @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([sourceType])
}

model ShopData {
  id        String   @id @default(cuid())
  tax       Int?
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KitchenTicket {
  id              String   @id @default(cuid())
  restaurantId    String
  orderId         String
  status          String   @default("making")
  selectedMinutes Int
  startedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  restaurant Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  order      Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items      KitchenTicketItem[]

  @@index([restaurantId, status])
  @@index([orderId])
}

model KitchenTicketItem {
  id              String @id @default(cuid())
  kitchenTicketId String
  productName     String
  quantity        Int

  kitchenTicket KitchenTicket @relation(fields: [kitchenTicketId], references: [id], onDelete: Cascade)

  @@index([kitchenTicketId])
}
